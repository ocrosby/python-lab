# Application
APP_NAME=fastapi-basic-example
APP_VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Logging
LOG_LEVEL=INFO
JSON_LOGGING=false

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Security
ALLOWED_HOSTS=["localhost","127.0.0.1","*.example.com"]

# Compression
GZIP_MINIMUM_SIZE=1000
GZIP_COMPRESSION_LEVEL=5
